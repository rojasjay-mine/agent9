{
  "$schema": "https://json.schemastore.org/wrangler.json",
  "name": "agent9",
  "account_id": "6b2fdf0e036db269314e45966c0ff757",
  "main": "functions/api.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "fixitagent.ai/*", "zone_name": "fixitagent.ai" },
    { "pattern": "www.fixitagent.ai/*", "zone_name": "fixitagent.ai" }
  ],
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    { "binding": "MEMORY", "id": "ba902d31d72444d9aae25bbb24a269e1" }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "unsafe": {
    "bindings": [
      {
        "type": "ratelimit",
        "name": "RL_GLOBAL",
        "namespace_id": "1001",
        "simple": { "limit": 60, "period": 60 }
      },
      {
        "type": "ratelimit",
        "name": "RL_API",
        "namespace_id": "1002",
        "simple": { "limit": 15, "period": 60 }
      }
    ]
  }
}
