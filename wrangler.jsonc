{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent9",
  "main": "functions/api.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "fixitagent.ai/*", "zone_name": "fixitagent.ai" },
    { "pattern": "www.fixitagent.ai/*", "zone_name": "fixitagent.ai" }
  ],
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    { "binding": "MEMORY", "id": "ba902d31d72444d9aae25bbb24a269e1" }
  ]
}
